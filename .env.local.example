# ─────────────────────────────────────────────────────────────
#  fe-pmtl/.env.local.example
#  Copy sang .env.local và điền giá trị thực
# ─────────────────────────────────────────────────────────────

# ── Strapi API ────────────────────────────────────────────────
NEXT_PUBLIC_STRAPI_API_URL=http://localhost:1337
# Server-side only — KHÔNG đặt NEXT_PUBLIC_ prefix!
STRAPI_API_TOKEN=your_strapi_api_token_here

# ── ISR Webhook ───────────────────────────────────────────────
REVALIDATE_SECRET=your_revalidate_secret_here

# ── Google OAuth ──────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ── Analytics: PostHog (tuỳ chọn) ────────────────────────────
# Đăng ký tại https://posthog.com (free tier có sẵn)
# Sau khi cài: npm install posthog-js
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Push Notifications (VAPID keys) ──────────────────────────
# Tạo VAPID keys: npx web-push generate-vapid-keys
# Sau khi cài: npm install web-push
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=BxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxE
# VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# VAPID_EMAIL=admin@phapmontamlinh.vn
# Bí mật để gọi /api/push/send từ cron job
# PUSH_SEND_SECRET=your_push_send_secret_here

# ── Redis ISR Cache (production) ──────────────────────────────
# Cài: npm install @neshca/cache-handler ioredis
# Để trống khi dev — dùng file system cache
# REDIS_URL=redis://127.0.0.1:6379
# Production (Upstash Redis free tier):
# REDIS_URL=rediss://default:xxx@xxx.upstash.io:6380

# ── Meilisearch (optional in local) ───────────────────────────
# Server-side search sẽ dùng 1 trong các key dưới đây nếu có.
# Local nhanh nhất là dùng master key; production nên dùng search-only key.
# Nếu recreate Meilisearch data volume, generated search/admin keys có thể đổi.
# Khi đó đọc lại GET /keys bằng master key và cập nhật MEILISEARCH_SEARCH_KEY.
# NEXT_PUBLIC_MEILISEARCH_HOST=http://localhost:7700
# MEILISEARCH_MASTER_KEY=your_local_master_key
# MEILISEARCH_SEARCH_KEY=your_search_only_key
# MEILISEARCH_BLOG_POST_INDEX=blog-post
